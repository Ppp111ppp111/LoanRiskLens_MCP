{
  "name": "altcredit-intelligence-platform",
  "version": "1.0.0",
  "description": "Alternative Credit Intelligence MCP Server for fintech companies",
  "private": true,
  "workspaces": [
    "apps/api",
    "packages/mcp-server",
    "langgraph-workflows",
    "credit-engine",
    "shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "seed": "NODE_PATH=. node scripts/seed-datasets.js",
    "seed:dry-run": "NODE_PATH=. node scripts/seed-datasets.js --dry-run",
    "dev": "NODE_PATH=. node apps/api/src/index.js",
    "dev:mcp": "NODE_PATH=. node packages/mcp-server/src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
